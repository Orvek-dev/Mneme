# Copy this file to .mneme/mneme-agent-hook.env, or set
# MNEME_AGENT_HOOK_CONFIG to an explicit profile path.
#
# The wrapper reads KEY=VALUE lines directly. It does not execute this file.
# CLI flags override environment variables, and environment variables override
# this profile.

MNEME_STORE=.mneme/mneme-v1.json
MNEME_AGENT_ID=codex
MNEME_SCOPE=private
MNEME_MAX_ITEMS=3

# Optional installed binary path. Leave unset to run through cargo inside this
# repository during local development.
# MNEME_BIN=/usr/local/bin/mneme

# Optional session-end command extractor. When set, wrapper end calls use the
# command extractor for --remember notes unless an explicit --extractor flag is
# provided.
# MNEME_EXTRACTOR_COMMAND=./mneme-extractor-wrapper

# Optional session-end outcome verifier. When set, wrapper end calls add
# --verifier-command for sessions that were started with --acceptance.
# MNEME_VERIFIER_COMMAND=scripts/mneme-outcome-verifier.py

# Optional verifier trust policy and manifest. Use strict only after pinning
# the verifier hash in .mneme/verifiers.json.
# MNEME_VERIFIER_POLICY=warn
# MNEME_VERIFIER_MANIFEST=.mneme/verifiers.json

# Optional Stop-hook loop guard. The state file stores the last failed gate id
# and retry count only; it should stay inside ignored .mneme/.
# MNEME_LOOP_MAX_ATTEMPTS=3
# MNEME_LOOP_STATE=.mneme/mneme-loop-state.json
