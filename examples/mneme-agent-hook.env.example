# Copy this file to .mneme/mneme-agent-hook.env, or set
# MNEME_AGENT_HOOK_CONFIG to an explicit profile path.
#
# The wrapper reads KEY=VALUE lines directly. It does not execute this file.
# CLI flags override environment variables, and environment variables override
# this profile.

MNEME_STORE=.mneme/mneme-v1.json
MNEME_AGENT_ID=codex
MNEME_SCOPE=private
MNEME_MAX_ITEMS=3

# Optional installed binary path. Leave unset to run through cargo inside this
# repository during local development.
# MNEME_BIN=/usr/local/bin/mneme
